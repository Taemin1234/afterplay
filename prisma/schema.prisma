generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum FeedKind {
  PLAYLIST
  ALBUM_LIST
  ARTIST_LIST
}

enum Role {
  USER
  ADMIN
}

enum MusicAliasType {
  TRACK_ARTIST
  TRACK_TITLE
  ALBUM_ARTIST
  ALBUM_TITLE
  ARTIST_NAME
}

// --------------------------------------------------------
// User (Supabase Auth user.id = UUID)
// --------------------------------------------------------
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  role  Role   @default(USER)
  nickname  String?  @unique
  nicknameSlug String? @unique
  avatarUrl String?
  isDeletedPlaceholder Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // ?닿? 留뚮뱺 由ъ뒪??
  playlists   Playlist[]
  albumLists  AlbumList[]
  artistLists ArtistList[]

  // ?닿? 醫뗭븘?뷀븳 由ъ뒪??
  playlistLikes   PlaylistLike[]
  albumListLikes  AlbumListLike[]
  artistListLikes ArtistListLike[]

  // ?닿? ??遺곷쭏??
  playlistBookmarks   PlaylistBookmark[]
  albumListBookmarks  AlbumListBookmark[]
  artistListBookmarks ArtistListBookmark[]

  // ?닿? ???볤???
  playlistComments   PlaylistComment[]
  albumListComments  AlbumListComment[]
  artistListComments ArtistListComment[]

  // 濡쒓렇??鍮꾨줈洹몄씤 議고쉶 異붿쟻
  playlistViews   PlaylistViewEvent[]
  albumListViews  AlbumListViewEvent[]
  artistListViews ArtistListViewEvent[]

  // ?붾줈??
  following Follow[] @relation("UserFollows")
  followers Follow[] @relation("UserFollowers")

  // 愿由ъ옄 異붿쿇 寃뚯떆臾?
  featuredPlaylists   FeaturedPlaylist[]   @relation("FeaturedPlaylistSetBy")
  featuredAlbumLists  FeaturedAlbumList[]  @relation("FeaturedAlbumListSetBy")
  featuredArtistLists FeaturedArtistList[] @relation("FeaturedArtistListSetBy")
}

// --------------------------------------------------------
// follow ?붾줈??
// --------------------------------------------------------
model Follow {
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId]) // 以묐났 ?붾줈??諛⑹?
  @@index([followingId])
  @@index([followerId])
}

// --------------------------------------------------------
// Playlist (怨??⑥쐞)
// --------------------------------------------------------
model Playlist {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  story      String     @db.Text
  visibility Visibility @default(PUBLIC)
  viewCount  Int        @default(0)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  tracks PlaylistTrack[]
  tags   PlaylistTag[]

  likes     PlaylistLike[]
  bookmarks PlaylistBookmark[]
  comments  PlaylistComment[]
  views     PlaylistViewEvent[]

  featuredSettings FeaturedPlaylist[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

// Spotify Track 罹먯떆 ?뚯씠釉?Spotify ?몃옓 ?뺣낫瑜??쒕퉬??DB??罹먯떆)
model Track {
  id        String @id @default(uuid()) @db.Uuid
  spotifyId String @unique

  title      String
  artist     String
  albumCover String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playlists PlaylistTrack[]
}

model PlaylistTrack {
  id         String @id @default(uuid()) @db.Uuid
  playlistId String @db.Uuid
  trackId    String @db.Uuid

  order   Int
  addedAt DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@unique([playlistId, order])   // 媛숈? ?뚮젅?대━?ㅽ듃?먯꽌 ?쒖꽌 以묐났 湲덉?
  @@unique([playlistId, trackId]) // 媛숈? 怨?以묐났 鍮꾪뿀??
  @@index([playlistId])
  @@index([trackId])
}

// --------------------------------------------------------
// AlbumList (?⑤쾾 ?⑥쐞) - Playlist? ?숈씪 ?쒖뒪??
// --------------------------------------------------------
model AlbumList {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  story      String     @db.Text
  visibility Visibility @default(PUBLIC)
  viewCount  Int        @default(0)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  albums AlbumEntry[]
  tags   AlbumListTag[]

  likes     AlbumListLike[]
  bookmarks AlbumListBookmark[]
  comments  AlbumListComment[]
  views     AlbumListViewEvent[]

  featuredSettings FeaturedAlbumList[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

// Spotify Album 罹먯떆 ?뚯씠釉?Spotify ?⑤쾾 ?뺣낫瑜??쒕퉬??DB??罹먯떆)
model Album {
  id        String @id @default(uuid()) @db.Uuid
  spotifyId String @unique

  title      String
  artist     String
  coverImage String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albumLists AlbumEntry[]
}

model AlbumEntry {
  id          String @id @default(uuid()) @db.Uuid
  albumListId String @db.Uuid
  albumId     String @db.Uuid

  order   Int
  addedAt DateTime @default(now())

  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  album     Album     @relation(fields: [albumId], references: [id], onDelete: Restrict)

  @@unique([albumListId, order])
  @@unique([albumListId, albumId]) // 媛숈? ?⑤쾾 以묐났 鍮꾪뿀??
  @@index([albumListId])
  @@index([albumId])
}

// --------------------------------------------------------
// ArtistList (?꾪떚?ㅽ듃 ?⑥쐞) - Playlist/AlbumList? ?숈씪 ?쒖뒪??// --------------------------------------------------------
model ArtistList {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  story      String     @db.Text
  visibility Visibility @default(PUBLIC)
  viewCount  Int        @default(0)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  artists ArtistEntry[]
  tags    ArtistListTag[]

  likes     ArtistListLike[]
  bookmarks ArtistListBookmark[]
  comments  ArtistListComment[]
  views     ArtistListViewEvent[]

  featuredSettings FeaturedArtistList[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

// Spotify Artist 罹먯떆 ?뚯씠釉?Spotify ?꾪떚?ㅽ듃 ?뺣낫瑜??쒕퉬??DB??罹먯떆)
model Artist {
  id        String @id @default(uuid()) @db.Uuid
  spotifyId String @unique

  name     String
  imageUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artistLists ArtistEntry[]
}

model ArtistEntry {
  id           String @id @default(uuid()) @db.Uuid
  artistListId String @db.Uuid
  artistId     String @db.Uuid

  order   Int
  addedAt DateTime @default(now())

  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  artist     Artist     @relation(fields: [artistId], references: [id], onDelete: Restrict)

  @@unique([artistListId, order])
  @@unique([artistListId, artistId]) // 같은 아티스트 중복 비허용
  @@index([artistListId])
  @@index([artistId])
}

// --------------------------------------------------------
// Tags (怨듯넻 ?쒓렇) - ?쒓렇 臾몄옄?댁쓣 以묐났 ?놁씠 愿由ы븯??留덉뒪???뚯씠釉?
// --------------------------------------------------------
model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  playlists  PlaylistTag[]
  albumLists AlbumListTag[]
  artistLists ArtistListTag[]
}

model PlaylistTag {
  playlistId String @db.Uuid
  tagId      Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([playlistId, tagId])
  @@index([tagId])
}

model AlbumListTag {
  albumListId String @db.Uuid
  tagId       Int

  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([albumListId, tagId])
  @@index([tagId])
}

model ArtistListTag {
  artistListId String @db.Uuid
  tagId        Int

  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artistListId, tagId])
  @@index([tagId])
}

// --------------------------------------------------------
// Likes - Playlist / AlbumList 遺꾨━ (媛???덉쟾)
// --------------------------------------------------------
model PlaylistLike {
  userId     String   @db.Uuid
  playlistId String   @db.Uuid
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId]) // 以묐났 醫뗭븘???꾨꼍 諛⑹?
  @@index([playlistId])
}

model AlbumListLike {
  userId      String   @db.Uuid
  albumListId String   @db.Uuid
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)

  @@id([userId, albumListId])
  @@index([albumListId])
}

model ArtistListLike {
  userId       String   @db.Uuid
  artistListId String   @db.Uuid
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)

  @@id([userId, artistListId])
  @@index([artistListId])
}

// --------------------------------------------------------
// 遺곷쭏??
// --------------------------------------------------------
model PlaylistBookmark {
  userId     String   @db.Uuid
  playlistId String   @db.Uuid
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@index([playlistId])
}

model AlbumListBookmark {
  userId      String   @db.Uuid
  albumListId String   @db.Uuid
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)

  @@id([userId, albumListId])
  @@index([albumListId])
}

model ArtistListBookmark {
  userId       String   @db.Uuid
  artistListId String   @db.Uuid
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)

  @@id([userId, artistListId])
  @@index([artistListId])
}

// --------------------------------------------------------
// 議고쉶??
// --------------------------------------------------------
model PlaylistViewEvent {
  id            String   @id @default(uuid()) @db.Uuid
  playlistId    String   @db.Uuid
  userId        String?  @db.Uuid
  deviceId      String?
  lastCountedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playlistId, userId])
  @@unique([playlistId, deviceId])
  @@index([playlistId, lastCountedAt])
  @@index([userId])
  @@index([deviceId])
}

model AlbumListViewEvent {
  id            String   @id @default(uuid()) @db.Uuid
  albumListId   String   @db.Uuid
  userId        String?  @db.Uuid
  deviceId      String?
  lastCountedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([albumListId, userId])
  @@unique([albumListId, deviceId])
  @@index([albumListId, lastCountedAt])
  @@index([userId])
  @@index([deviceId])
}

model ArtistListViewEvent {
  id            String   @id @default(uuid()) @db.Uuid
  artistListId  String   @db.Uuid
  userId        String?  @db.Uuid
  deviceId      String?
  lastCountedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artistListId, userId])
  @@unique([artistListId, deviceId])
  @@index([artistListId, lastCountedAt])
  @@index([userId])
  @@index([deviceId])
}


// --------------------------------------------------------
// 愿由ъ옄 異붿쿇 寃뚯떆臾?
// --------------------------------------------------------
model FeaturedPlaylistSection {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlists FeaturedPlaylist[]

  @@index([isActive, priority, createdAt(sort: Desc)])
}

model FeaturedPlaylist {
  id          String   @id @default(uuid()) @db.Uuid
  playlistId  String   @db.Uuid
  sectionId   String   @db.Uuid
  setByUserId String?  @db.Uuid
  note        String?  @db.Text
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlist  Playlist               @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  section   FeaturedPlaylistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  setByUser User?                  @relation("FeaturedPlaylistSetBy", fields: [setByUserId], references: [id], onDelete: SetNull)

  @@unique([playlistId, sectionId])
  @@index([sectionId, isActive, priority, createdAt(sort: Desc)])
  @@index([startsAt, endsAt])
  @@index([setByUserId])
}

model FeaturedAlbumListSection {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  albumLists FeaturedAlbumList[]

  @@index([isActive, priority, createdAt(sort: Desc)])
}

model FeaturedAlbumList {
  id          String   @id @default(uuid()) @db.Uuid
  albumListId String   @db.Uuid
  sectionId   String   @db.Uuid
  setByUserId String?  @db.Uuid
  note        String?  @db.Text
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  albumList AlbumList               @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  section   FeaturedAlbumListSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  setByUser User?                   @relation("FeaturedAlbumListSetBy", fields: [setByUserId], references: [id], onDelete: SetNull)

  @@unique([albumListId, sectionId])
  @@index([sectionId, isActive, priority, createdAt(sort: Desc)])
  @@index([startsAt, endsAt])
  @@index([setByUserId])
}

model FeaturedArtistListSection {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artistLists FeaturedArtistList[]

  @@index([isActive, priority, createdAt(sort: Desc)])
}

model FeaturedArtistList {
  id           String   @id @default(uuid()) @db.Uuid
  artistListId String   @db.Uuid
  sectionId    String   @db.Uuid
  setByUserId  String?  @db.Uuid
  note         String?  @db.Text
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artistList ArtistList                @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  section    FeaturedArtistListSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  setByUser  User?                     @relation("FeaturedArtistListSetBy", fields: [setByUserId], references: [id], onDelete: SetNull)

  @@unique([artistListId, sectionId])
  @@index([sectionId, isActive, priority, createdAt(sort: Desc)])
  @@index([startsAt, endsAt])
  @@index([setByUserId])
}

// --------------------------------------------------------
// ?볤?
// --------------------------------------------------------
model PlaylistComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  userId     String @db.Uuid
  playlistId String @db.Uuid

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([playlistId, createdAt])
  @@index([userId])
}

model AlbumListComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  userId      String @db.Uuid
  albumListId String @db.Uuid

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([albumListId, createdAt])
  @@index([userId])
}

model ArtistListComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  userId       String @db.Uuid
  artistListId String @db.Uuid

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([artistListId, createdAt])
  @@index([userId])
}

// --------------------------------------------------------
// ListFeed - ?꾩껜 ?쇰뱶
// --------------------------------------------------------
model ListFeed {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  kind      FeedKind
  refId     String   @db.Uuid
  createdAt DateTime @default(now())

  @@unique([userId, kind, refId])
  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([kind, refId])
}

model MusicSearchAlias {
  id        Int            @id @default(autoincrement())
  type      MusicAliasType
  canonical String
  alias     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([type, canonical, alias])
  @@index([alias])
  @@index([canonical])
}


