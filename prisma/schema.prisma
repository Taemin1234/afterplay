generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum FeedKind {
  PLAYLIST
  ALBUM_LIST
  ARTIST_LIST
}

enum Role {
  USER
  ADMIN
}

enum MusicAliasType {
  TRACK_ARTIST
  TRACK_TITLE
  ALBUM_ARTIST
  ALBUM_TITLE
  ARTIST_NAME
}

enum PollItemType {
  TRACK
  ALBUM
}

enum PollStatus {
  OPEN
  CLOSED
}

// --------------------------------------------------------
// User (Supabase Auth user.id = UUID)
// --------------------------------------------------------
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  role  Role   @default(USER)
  nickname  String?  @unique
  nicknameSlug String? @unique
  avatarUrl String?
  isDeletedPlaceholder Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // 내가 만든 리스트
  playlists   Playlist[]
  albumLists  AlbumList[]
  artistLists ArtistList[]

  // 내가 좋아요한 리스트
  playlistLikes   PlaylistLike[]
  albumListLikes  AlbumListLike[]
  artistListLikes ArtistListLike[]

  // 내가 한 북마크
  playlistBookmarks   PlaylistBookmark[]
  albumListBookmarks  AlbumListBookmark[]
  artistListBookmarks ArtistListBookmark[]

  // 내가 쓴 댓글들
  playlistComments   PlaylistComment[]
  albumListComments  AlbumListComment[]
  artistListComments ArtistListComment[]
  musicPollComments  MusicPollComment[]

  // 로그인/비로그인 조회 추적
  playlistViews   PlaylistViewEvent[]
  albumListViews  AlbumListViewEvent[]
  artistListViews ArtistListViewEvent[]

  createdMusicPolls MusicPoll[]     @relation("MusicPollCreatedBy")
  musicPollVotes    MusicPollVote[]

  // 팔로우
  following Follow[] @relation("UserFollows")
  followers Follow[] @relation("UserFollowers")

  // 관리자 추천 게시물
  featuredArtistLists FeaturedArtistList[] @relation("FeaturedArtistListSetBy")
  featuredItems       FeaturedItem[]       @relation("FeaturedItemSetBy")
}

// --------------------------------------------------------
// follow 팔로우
// --------------------------------------------------------
model Follow {
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId]) // 중복 팔로우 방지
  @@index([followingId])
  @@index([followerId])
}

// --------------------------------------------------------
// Playlist (곡 단위)
// --------------------------------------------------------
model Playlist {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  story      String     @db.Text
  visibility Visibility @default(PUBLIC)
  viewCount  Int        @default(0)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  tracks PlaylistTrack[]
  tags   PlaylistTag[]

  likes     PlaylistLike[]
  bookmarks PlaylistBookmark[]
  comments  PlaylistComment[]
  views     PlaylistViewEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

// Spotify Track 캐시 테이블(Spotify 트랙 정보를 서비스 DB에 캐시)
model Track {
  id        String @id @default(uuid()) @db.Uuid
  spotifyId String @unique

  title      String
  artist     String
  albumCover String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playlists PlaylistTrack[]
  pollOptions MusicPollOption[]
}

model PlaylistTrack {
  id         String @id @default(uuid()) @db.Uuid
  playlistId String @db.Uuid
  trackId    String @db.Uuid

  order   Int
  addedAt DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@unique([playlistId, order])   // 같은 플레이리스트에서 순서 중복 금지
  @@unique([playlistId, trackId]) // 같은 곡 중복 비허용
  @@index([playlistId])
  @@index([trackId])
}

// --------------------------------------------------------
// AlbumList (앨범 단위) - Playlist와 동일 시스템
// --------------------------------------------------------
model AlbumList {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  story      String     @db.Text
  visibility Visibility @default(PUBLIC)
  viewCount  Int        @default(0)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  albums AlbumEntry[]
  tags   AlbumListTag[]

  likes     AlbumListLike[]
  bookmarks AlbumListBookmark[]
  comments  AlbumListComment[]
  views     AlbumListViewEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

// Spotify Album 캐시 테이블(Spotify 앨범 정보를 서비스 DB에 캐시)
model Album {
  id        String @id @default(uuid()) @db.Uuid
  spotifyId String @unique

  title      String
  artist     String
  coverImage String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albumLists AlbumEntry[]
  pollOptions MusicPollOption[]
}

model AlbumEntry {
  id          String @id @default(uuid()) @db.Uuid
  albumListId String @db.Uuid
  albumId     String @db.Uuid

  order   Int
  addedAt DateTime @default(now())

  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  album     Album     @relation(fields: [albumId], references: [id], onDelete: Restrict)

  @@unique([albumListId, order])
  @@unique([albumListId, albumId]) // 같은 앨범 중복 비허용
  @@index([albumListId])
  @@index([albumId])
}

// --------------------------------------------------------
// ArtistList (아티스트 단위) - Playlist/AlbumList와 동일 시스템
// --------------------------------------------------------
model ArtistList {
  id         String     @id @default(uuid()) @db.Uuid
  title      String
  story      String     @db.Text
  visibility Visibility @default(PUBLIC)
  viewCount  Int        @default(0)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  artists ArtistEntry[]
  tags    ArtistListTag[]

  likes     ArtistListLike[]
  bookmarks ArtistListBookmark[]
  comments  ArtistListComment[]
  views     ArtistListViewEvent[]

  featuredSettings FeaturedArtistList[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

// Spotify Artist 캐시 테이블(Spotify 아티스트 정보를 서비스 DB에 캐시)
model Artist {
  id        String @id @default(uuid()) @db.Uuid
  spotifyId String @unique

  name     String
  imageUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artistLists ArtistEntry[]
}

model ArtistEntry {
  id           String @id @default(uuid()) @db.Uuid
  artistListId String @db.Uuid
  artistId     String @db.Uuid

  order   Int
  addedAt DateTime @default(now())

  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  artist     Artist     @relation(fields: [artistId], references: [id], onDelete: Restrict)

  @@unique([artistListId, order])
  @@unique([artistListId, artistId]) // 같은 아티스트 중복 비허용
  @@index([artistListId])
  @@index([artistId])
}

// --------------------------------------------------------
// Tags (공통 태그) - 태그 문자열을 중복 없이 관리하는 마스터 테이블
// --------------------------------------------------------
model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  playlists  PlaylistTag[]
  albumLists AlbumListTag[]
  artistLists ArtistListTag[]
}

model PlaylistTag {
  playlistId String @db.Uuid
  tagId      Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([playlistId, tagId])
  @@index([tagId])
}

model AlbumListTag {
  albumListId String @db.Uuid
  tagId       Int

  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([albumListId, tagId])
  @@index([tagId])
}

model ArtistListTag {
  artistListId String @db.Uuid
  tagId        Int

  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artistListId, tagId])
  @@index([tagId])
}

// --------------------------------------------------------
// Likes - Playlist / AlbumList 분리 (가장 안전)
// --------------------------------------------------------
model PlaylistLike {
  userId     String   @db.Uuid
  playlistId String   @db.Uuid
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId]) // 중복 좋아요 완벽 방지
  @@index([playlistId])
}

model AlbumListLike {
  userId      String   @db.Uuid
  albumListId String   @db.Uuid
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)

  @@id([userId, albumListId])
  @@index([albumListId])
}

model ArtistListLike {
  userId       String   @db.Uuid
  artistListId String   @db.Uuid
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)

  @@id([userId, artistListId])
  @@index([artistListId])
}

// --------------------------------------------------------
// 북마크
// --------------------------------------------------------
model PlaylistBookmark {
  userId     String   @db.Uuid
  playlistId String   @db.Uuid
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@index([playlistId])
}

model AlbumListBookmark {
  userId      String   @db.Uuid
  albumListId String   @db.Uuid
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)

  @@id([userId, albumListId])
  @@index([albumListId])
}

model ArtistListBookmark {
  userId       String   @db.Uuid
  artistListId String   @db.Uuid
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)

  @@id([userId, artistListId])
  @@index([artistListId])
}

// --------------------------------------------------------
// 조회수
// --------------------------------------------------------
model PlaylistViewEvent {
  id            String   @id @default(uuid()) @db.Uuid
  playlistId    String   @db.Uuid
  userId        String?  @db.Uuid
  deviceId      String?
  lastCountedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playlistId, userId])
  @@unique([playlistId, deviceId])
  @@index([playlistId, lastCountedAt])
  @@index([userId])
  @@index([deviceId])
}

model AlbumListViewEvent {
  id            String   @id @default(uuid()) @db.Uuid
  albumListId   String   @db.Uuid
  userId        String?  @db.Uuid
  deviceId      String?
  lastCountedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([albumListId, userId])
  @@unique([albumListId, deviceId])
  @@index([albumListId, lastCountedAt])
  @@index([userId])
  @@index([deviceId])
}

model ArtistListViewEvent {
  id            String   @id @default(uuid()) @db.Uuid
  artistListId  String   @db.Uuid
  userId        String?  @db.Uuid
  deviceId      String?
  lastCountedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([artistListId, userId])
  @@unique([artistListId, deviceId])
  @@index([artistListId, lastCountedAt])
  @@index([userId])
  @@index([deviceId])
}


// --------------------------------------------------------
// 관리자 추천 게시물
// --------------------------------------------------------
model FeaturedSection {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items FeaturedItem[]

  @@index([isActive, priority, createdAt(sort: Desc)])
}

model FeaturedItem {
  id          String   @id @default(uuid()) @db.Uuid
  sectionId   String   @db.Uuid
  kind        FeedKind
  refId       String   @db.Uuid
  setByUserId String?  @db.Uuid
  note        String?  @db.Text
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section   FeaturedSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  setByUser User?           @relation("FeaturedItemSetBy", fields: [setByUserId], references: [id], onDelete: SetNull)

  @@unique([sectionId, kind, refId])
  @@index([sectionId, isActive, priority, createdAt(sort: Desc)])
  @@index([kind, refId])
  @@index([startsAt, endsAt])
  @@index([setByUserId])
}

model FeaturedArtistListSection {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artistLists FeaturedArtistList[]

  @@index([isActive, priority, createdAt(sort: Desc)])
}

model FeaturedArtistList {
  id           String   @id @default(uuid()) @db.Uuid
  artistListId String   @db.Uuid
  sectionId    String   @db.Uuid
  setByUserId  String?  @db.Uuid
  note         String?  @db.Text
  priority     Int      @default(0)
  isActive     Boolean  @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  artistList ArtistList                @relation(fields: [artistListId], references: [id], onDelete: Cascade)
  section    FeaturedArtistListSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  setByUser  User?                     @relation("FeaturedArtistListSetBy", fields: [setByUserId], references: [id], onDelete: SetNull)

  @@unique([artistListId, sectionId])
  @@index([sectionId, isActive, priority, createdAt(sort: Desc)])
  @@index([startsAt, endsAt])
  @@index([setByUserId])
}

// --------------------------------------------------------
// 댓글
// --------------------------------------------------------
model PlaylistComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  userId     String @db.Uuid
  playlistId String @db.Uuid

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([playlistId, createdAt])
  @@index([userId])
}

model AlbumListComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  userId      String @db.Uuid
  albumListId String @db.Uuid

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumList AlbumList @relation(fields: [albumListId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([albumListId, createdAt])
  @@index([userId])
}

model ArtistListComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  userId       String @db.Uuid
  artistListId String @db.Uuid

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistList ArtistList @relation(fields: [artistListId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([artistListId, createdAt])
  @@index([userId])
}

// --------------------------------------------------------
// ListFeed - 전체 피드
// --------------------------------------------------------
model ListFeed {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  kind      FeedKind
  refId     String   @db.Uuid
  createdAt DateTime @default(now())

  @@unique([userId, kind, refId])
  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([kind, refId])
  @@index([createdAt(sort: Desc), id(sort: Desc)], map: "ListFeed_createdAt_id_desc_idx")
  @@index([kind, createdAt(sort: Desc), id(sort: Desc)], map: "ListFeed_kind_createdAt_id_desc_idx")
}

model MusicSearchAlias {
  id        Int            @id @default(autoincrement())
  type      MusicAliasType
  canonical String
  alias     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([type, canonical, alias])
  @@index([alias])
  @@index([canonical])
}

// --------------------------------------------------------
// Music Polls - 관리자 생성형 곡/앨범 대결 투표
// --------------------------------------------------------
model MusicPoll {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String?      @db.Text
  itemType    PollItemType
  status      PollStatus   @default(OPEN)

  startsAt DateTime?
  endsAt   DateTime?
  closedAt DateTime?

  createdById String @db.Uuid
  createdBy   User   @relation("MusicPollCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  options  MusicPollOption[]
  votes    MusicPollVote[]
  comments MusicPollComment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, startsAt, endsAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([createdById])
}

model MusicPollOption {
  id     String @id @default(uuid()) @db.Uuid
  pollId String @db.Uuid
  order  Int

  trackId String? @db.Uuid
  albumId String? @db.Uuid

  spotifyId           String
  titleSnapshot       String
  artistSnapshot      String
  imageUrlSnapshot    String
  releaseDateSnapshot String?
  description         String? @db.Text

  poll  MusicPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  track Track?    @relation(fields: [trackId], references: [id], onDelete: Restrict)
  album Album?    @relation(fields: [albumId], references: [id], onDelete: Restrict)
  votes MusicPollVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollId, order])
  @@index([pollId])
  @@index([trackId])
  @@index([albumId])
  @@index([titleSnapshot])
}

model MusicPollVote {
  id       String  @id @default(uuid()) @db.Uuid
  pollId   String  @db.Uuid
  optionId String  @db.Uuid
  userId   String? @db.Uuid

  poll   MusicPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option MusicPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollId, userId])
  @@index([pollId, optionId])
  @@index([optionId])
  @@index([userId])
}

model MusicPollComment {
  id      String @id @default(uuid()) @db.Uuid
  content String

  pollId String @db.Uuid
  userId String @db.Uuid

  poll MusicPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([pollId, createdAt])
  @@index([userId])
}


